# Collector
COLLECTOR_HOST=127.0.0.1
COLLECTOR_PORT=8787
# COLLECTOR_BASE_URL=http://127.0.0.1:8787
# COLLECTOR_DATA_DIR=data

# Audio capture
AUDIO_CAPTURE_ENABLED=0
AUDIO_CAPTURE_INPUT_DEVICE=
AUDIO_CAPTURE_SPOOL_DIR=data/spool/audio
AUDIO_CAPTURE_SAMPLE_RATE=16000
AUDIO_CAPTURE_FRAME_MS=20
AUDIO_CAPTURE_VAD_MODE=2
AUDIO_CAPTURE_START_TRIGGER_MS=240
AUDIO_CAPTURE_START_WINDOW_MS=400
AUDIO_CAPTURE_END_SILENCE_MS=900
AUDIO_CAPTURE_PRE_ROLL_MS=300
AUDIO_CAPTURE_MIN_SEGMENT_MS=1000
AUDIO_CAPTURE_MAX_SEGMENT_MS=30000
AUDIO_CAPTURE_REQUEST_TIMEOUT_S=20
AUDIO_CAPTURE_MAX_UPLOAD_PER_CYCLE=10
AUDIO_CAPTURE_MIN_RMS=200
AUDIO_CAPTURE_LOG_LEVEL=INFO

# Screen capture
SCREEN_CAPTURE_ENABLED=0
SCREEN_CAPTURE_FPS=1
SCREEN_CAPTURE_MONITOR_INDEX=1
SCREEN_CAPTURE_SAVE_PNG=0
SCREEN_CAPTURE_OUT_DIR=screen_capture/debug_output
SCREEN_CAPTURE_REQUEST_TIMEOUT_S=15

# Processor paths
PROCESSOR_DATA_DIR=data
PROCESSOR_VAULT_DIR=vault
PROCESSOR_MAX_EVENTS_PER_RUN=
PROCESSOR_OVERWRITE=0
PROCESSOR_ENABLED=0
# PROCESSOR_ARGS=--day 2026-03-10 --dry-run

# Runner
RUNNER_LOG_LEVEL=INFO

# AI config paths
LLM_CONFIG_PATH=config/llm.json
STT_CONFIG_PATH=config/stt.json
OCR_CONFIG_PATH=config/ocr.json

# OpenAI
OPENAI_API_KEY=

# Gemini
GEMINI_API_KEY=
